# --- Backend ---
# Uses Node's built-in node:sqlite. Path is relative to the backend/ folder.
# Defaults to backend/data/app.db if unset.
DATABASE_FILE="data/app.db"
JWT_SECRET="change-me-in-production-please-use-a-long-random-string"
JWT_EXPIRES_IN="7d"
PORT=4000
CORS_ORIGIN="http://localhost:5173"

# --- Frontend (Vite) ---
# Vite only exposes vars prefixed with VITE_
VITE_API_URL="http://localhost:4000"
